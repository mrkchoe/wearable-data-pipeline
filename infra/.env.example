# Copy to repo root as `.env` (docker-compose and local tools load it from project root).
# Postgres (warehouse + Airflow can use the same DB in dev, or separate — see docker env overrides)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wearable
DB_USER=wearable
DB_PASSWORD=wearable

# Local CSV drop folder (simulated external feed)
DATA_DROP_DIR=./sample_data

# S3-compatible lake (use MinIO locally: http://localhost:9000)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=wearable-lake
S3_PREFIX=raw

# Ingestion / pipeline
PIPELINE_DATA_DIR=./sample_data
PIPELINE_USE_MANIFEST=1
LOG_LEVEL=INFO

# Airflow (override in docker/docker-compose.yml or pass when bringing up the stack)
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
